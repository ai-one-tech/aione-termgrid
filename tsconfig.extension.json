{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "preserve",
    "outDir": "./out",
    "rootDir": "./src/extension",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/extension/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "out", "dist", "src/webview"]
}
