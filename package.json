{
  "name": "aione-termgrid",
  "displayName": "AiOne TermGrid",
  "description": "Batch manage multiple terminals in a grid layout",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:termgrid",
    "workspaceContains:.term-grid/*.tg"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "termgrid",
        "aliases": [
          "TermGrid",
          "tg"
        ],
        "extensions": [
          ".tg"
        ],
        "icon": {
          "light": "media/icon-light.svg",
          "dark": "media/icon-dark.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "aioneTermGrid.editor",
        "displayName": "TermGrid Editor",
        "selector": [
          {
            "filenamePattern": "*.tg"
          }
        ],
        "priority": "default"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "termGridSidebar",
          "name": "TermGrid",
          "when": "workspaceHasTermGrid"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "termGridContainer",
          "title": "TermGrid",
          "icon": "media/termgrid-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "termGrid.startAll",
        "title": "Start All",
        "icon": "$(play)"
      },
      {
        "command": "termGrid.stopAll",
        "title": "Stop All",
        "icon": "$(stop)"
      },
      {
        "command": "termGrid.restartAll",
        "title": "Restart All",
        "icon": "$(refresh)"
      },
      {
        "command": "termGrid.createNew",
        "title": "New TermGrid Config",
        "icon": "$(add)"
      },
      {
        "command": "termGrid.refreshTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "termGrid.createNew",
          "when": "view == termGridSidebar",
          "group": "navigation"
        },
        {
          "command": "termGrid.refreshTree",
          "when": "view == termGridSidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "termGrid.startAll",
          "when": "view == termGridSidebar",
          "group": "inline"
        },
        {
          "command": "termGrid.stopAll",
          "when": "view == termGridSidebar",
          "group": "inline"
        },
        {
          "command": "termGrid.restartAll",
          "when": "view == termGridSidebar",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "dev:webview": "vite build --watch --mode development",
    "dev:extension": "tsup --watch",
    "dev": "concurrently \"npm run dev:webview\" \"npm run dev:extension\"",
    "build:webview": "vite build",
    "build:extension": "tsup",
    "build": "npm run build:webview && npm run build:extension",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^1.4.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
